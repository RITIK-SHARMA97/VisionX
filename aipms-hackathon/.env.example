# === MQTT Configuration ===
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_QOS=1
MQTT_TIMEOUT=60

# === Database ===
DATABASE_URL=sqlite:///./aipms.db
SQLITE_DB_PATH=./aipms.db

# === Models ===
MODEL_DIR=./models/saved
MODEL_VERSION=1.0.0

# === Simulator ===
SIMULATOR_UNITS=3
SIMULATOR_HZ=1
SIMULATOR_SPEED_MULTIPLIER=1.0

# === API ===
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
LOG_LEVEL=INFO

# === Dashboard ===
STREAMLIT_PORT=8501
STREAMLIT_SERVER_HEADLESS=false

# === Inference ===
INFERENCE_BATCH_SIZE=32
INFERENCE_TIMEOUT_MS=100
ANOMALY_THRESHOLD_WARNING=0.40
ANOMALY_THRESHOLD_CRITICAL=0.70

# === Features ===
FEATURE_WINDOW_SIZE=5
RUL_CONFIDENCE_PERCENTILE=95

# === Debug ===
DEBUG=false
